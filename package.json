{
  "name": "sentinel-oversight",
  "version": "0.1.0",
  "description": "Human-in-the-loop approval for AI agent actions — one wrapper, magic-link approve/reject.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./langchain": {
      "import": "./dist/adapters/langchain.js",
      "types": "./dist/adapters/langchain.d.ts"
    },
    "./mastra": {
      "import": "./dist/adapters/mastra.js",
      "types": "./dist/adapters/mastra.d.ts"
    },
    "./ai-sdk": {
      "import": "./dist/adapters/ai-sdk.js",
      "types": "./dist/adapters/ai-sdk.d.ts"
    },
    "./openai-agents": {
      "import": "./dist/adapters/openai-agents.js",
      "types": "./dist/adapters/openai-agents.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test tests/serializable.test.mjs tests/idempotency.test.mjs tests/timeout.test.mjs tests/pagination.test.mjs tests/ai-sdk.test.mjs tests/openai-agents.test.mjs",
    "smoke": "node tests/smoke.mjs",
    "demo": "node examples/demo.mjs",
    "gen:types": "openapi-typescript https://api.pauseapi.app/openapi.json -o src/generated/api.d.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "approval",
    "human-in-the-loop",
    "sentinel",
    "agent-safety",
    "llm",
    "guardrails",
    "oversight"
  ],
  "author": "Christopher Sellers / RegEngine, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PetrefiedThunder/sentinel-sdk-js"
  },
  "homepage": "https://pauseapi.app",
  "bugs": "https://github.com/PetrefiedThunder/sentinel-sdk-js/issues",
  "engines": {
    "node": ">=18.17"
  },
  "peerDependencies": {
    "@openai/agents": ">=0.1.0",
    "ai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@openai/agents": {
      "optional": true
    },
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^25.9.3",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "openapi-typescript": "^7.4.0",
    "semantic-release": "^25.0.5",
    "typescript": "^5.5.0"
  }
}
